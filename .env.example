# Panoptes credentials for password-based auth (optional)
# Without these, the app runs in anonymous mode.
VITE_PANOPTES_USERNAME=
VITE_PANOPTES_PASSWORD=

# OAuth — register at https://panoptes.zooniverse.org/oauth/applications
# Set all three to enable "Log in with Zooniverse" button.
# See README.md for setup instructions.
VITE_OAUTH_CLIENT_ID=
VITE_OAUTH_CLIENT_SECRET=
VITE_OAUTH_REDIRECT_URI=
